# Response headers for the hosted PWA (Netlify / Cloudflare Pages syntax).
# Deliberately no Content-Security-Policy: MapLibre uses blob: web workers, the
# opt-in OpenStreetMap basemap fetches tiles cross-origin, and postcard photos
# render as data: URLs — a wrong CSP would break those. The headers below are the
# safe, privacy-friendly set that never affects resource loading.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  # strict-origin-when-cross-origin: send only our ORIGIN (never the path/query)
  # as the Referer on cross-origin requests. The opt-in OpenStreetMap tile server
  # BLOCKS requests with no Referer ("Referer is required"), so `no-referrer` broke
  # it; this is the least-leaky policy OSM accepts and is also the browser default.
  # Same-origin navigations still send no path leak beyond the origin. (Mirrored by
  # the <meta name="referrer"> in index.html so dev/preview/native honour it too.)
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Content-hashed build assets are immutable — cache them hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The service worker must revalidate so app updates ship promptly.
/sw.js
  Cache-Control: no-cache
